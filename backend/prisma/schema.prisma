generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("SuperAdmin")
  createdAt DateTime @default(now())
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  icon      String?
  medicines Medicine[]
  createdAt DateTime   @default(now())
}

model Manufacturer {
  id        Int        @id @default(autoincrement())
  name      String
  country   String
  medicines Medicine[]
  createdAt DateTime   @default(now())
}

model Medicine {
  id                   Int                       @id @default(autoincrement())
  name                 String
  internationalName    String?
  activeSubstance      String?
  description          String?
  price                Float
  discountPrice        Float?
  wholesalePrice       Float?
  prescriptionRequired Boolean                   @default(false)
  ageLimit             String?
  quantityInStock      Int                       @default(0)
  batchNumber          String?
  expiryDate           DateTime?
  
  category             Category?                 @relation(fields: [categoryId], references: [id])
  categoryId           Int?
  
  manufacturer         Manufacturer?             @relation(fields: [manufacturerId], references: [id])
  manufacturerId       Int?

  details              MedicineDetail?
  usage                MedicineUsage?
  sideEffects          MedicineSideEffect?
  contraindications    MedicineContraindication?
  storage              MedicineStorage?
  images               MedicineImage[]
  orderItems           OrderItem[]
  reviews              Review[]
  
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
}

model MedicineDetail {
  id                   Int      @id @default(autoincrement())
  medicine             Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId           Int      @unique
  pharmacologicalGroup String?
  packageType          String?
  packageSize          String?
}

model MedicineUsage {
  id               Int      @id @default(autoincrement())
  medicine         Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId       Int      @unique
  usageAreas       String?
  adultDosage      String?
  childDosage      String?
  howToUse         String?
  timesPerDay      String?
  beforeOrAfterMeal String?
}

model MedicineSideEffect {
  id         Int      @id @default(autoincrement())
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId Int      @unique
  effects    String?    // Stored as stringified JSON
}

model MedicineContraindication {
  id         Int      @id @default(autoincrement())
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId Int      @unique
  conditions String?    // Stored as stringified JSON
}

model MedicineStorage {
  id          Int      @id @default(autoincrement())
  medicine    Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId  Int      @unique
  temperature String?
  humidity    String?
  light       String?
  shelfLife   String?
}

model MedicineImage {
  id         Int      @id @default(autoincrement())
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  medicineId Int
  url        String
  isPrimary  Boolean  @default(false)
}

model User {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String   @unique
  password    String
  address     String?
  role        String   @default("USER") // USER, B2B_PARTNER
  companyName String?
  tin         String?
  orders      Order[]
  createdAt   DateTime @default(now())
}

model Order {
  id          Int         @id @default(autoincrement())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  status      String      @default("NEW") // NEW, DELIVERING, COMPLETED, CANCELLED
  totalAmount Float
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    Int
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  medicineId Int
  quantity   Int
  price      Float
}

model SearchLog {
  id        Int      @id @default(autoincrement())
  query     String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int?
  username  String
  action    String
  details   String
  createdAt DateTime @default(now())
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  image       String?
  author      String   @default("BIO NEX STAR Farmatsevt")
  published   Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  medicineId Int
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  userName   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

